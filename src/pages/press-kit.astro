---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Press Kit"
  description="Official press kit for Draigon Idle — screenshots, key facts, and media assets for journalists and content creators."
>
  <section class="section" aria-labelledby="press-title">
    <div class="container">
      <p class="section-label">Media Resources</p>
      <h1 class="section-title" id="press-title">Press Kit</h1>
      <p class="section-body">
        Welcome, press and content creators. Everything you need to cover
        Draigon Idle is here — facts, branding guidelines, and screenshots.
        For inquiries, contact us at
        <a href="mailto:press@stonemillstudios.com">press@stonemillstudios.com</a>.
      </p>

      <div class="press-grid">
        <!-- Key Facts -->
        <div class="press-card">
          <h2>Key Facts</h2>
          <dl>
            <dt>Title</dt>
            <dd>Draigon Idle</dd>

            <dt>Developer</dt>
            <dd>Stonemill Studios</dd>

            <dt>Genre</dt>
            <dd>Narrative Idle Adventure RPG</dd>

            <dt>Platforms</dt>
            <dd>iOS, Android</dd>

            <dt>Status</dt>
            <dd>In Development</dd>

            <dt>Price</dt>
            <dd>Free to Play</dd>

            <dt>Languages</dt>
            <dd>English (more coming)</dd>
          </dl>
        </div>

        <!-- Description -->
        <div class="press-card">
          <h2>About the Game</h2>
          <p style="font-size: var(--text-sm); color: var(--color-text-muted); line-height: var(--leading-normal); margin-bottom: var(--space-4);">
            Draigon Idle is a narrative idle RPG set in The Draigonlands — a
            post-golden-age continent shaped by the departure of the draigons,
            ancient architect beings whose absence left ruins saturated with
            residual power. You play as a wandering adventurer and guild leader:
            building outposts across six distinct regions, running quest chains,
            and sending recruited companions on expeditions while you're away.
          </p>
          <p style="font-size: var(--text-sm); color: var(--color-text-muted); line-height: var(--leading-normal);">
            Progression is driven by quests, exploration, and discovery — not
            mindless clicking. Each region has its own visual identity, faction
            politics, and gameplay flavor. The world moves forward while you're
            offline; the decisions you make when you return are what shape your
            story.
          </p>
        </div>

        <!-- Download Assets -->
        <div class="press-card">
          <h2>Assets</h2>
          <p style="font-size: var(--text-sm); color: var(--color-text-muted); margin-bottom: var(--space-4);">
            Press assets including logos, screenshots, and promotional art will
            be available at launch.
          </p>
          <button class="btn btn-outline" disabled>
            Download Press Kit (Coming Soon)
          </button>
        </div>

        <!-- Screenshots Placeholder -->
        <div class="press-card" style="grid-column: 1 / -1;">
          <h2>Screenshots</h2>
          <p style="font-size: var(--text-sm); color: var(--color-text-muted); margin-bottom: var(--space-4);">
            Screenshots will be posted here as the game approaches launch.
          </p>
          <div
            style="
              display: grid;
              grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
              gap: var(--space-4);
            "
            aria-label="Screenshot gallery placeholder"
          >
            {
              Array.from({ length: 4 }).map((_, i) => (
                <div
                  style="
                    aspect-ratio: 9/16;
                    background-color: var(--color-bg-elevated);
                    border: 1px dashed var(--color-border);
                    border-radius: var(--radius-md);
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    color: var(--color-text-muted);
                    font-size: var(--text-xs);
                  "
                  aria-label={`Screenshot placeholder ${i + 1}`}
                >
                  Screenshot {i + 1}
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
