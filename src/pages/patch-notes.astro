---
import BaseLayout from "../layouts/BaseLayout.astro";

type ChangeItem = string | { section: string };

const patches: {
  version: string;
  date: string;
  title: string;
  type?: "devlog" | "patch";
  intro?: string;
  changes: ChangeItem[];
}[] = [
  {
    version: "0.3.0",
    date: "2026-03-28",
    type: "devlog",
    title: "Two Regions. One Very Stressful Month.",
    intro:
      "The forest showed up first. It had opinions. Then the mountain showed up and had more opinions, mostly about mithril and who gets to touch it. Both regions are now open. Everyone survived.",
    changes: [
      { section: "Ashenveil Woods" },
      "Ashenveil is fully built: 25 quests (3 main, 18 side, 4 faction), 12 NPCs, 8 discovery nodes, 3 expedition destinations (Grove Patrol, Deep Forest, Draigon Ruins), and 6 outpost buildings (Canopy Hall, Herbalist Shop, Enchanting Altar, Druid Sanctum, Scouts Post, Sanctuary). The forest has layers. You'll find most of them.",
      "The Verdant Circle arrive as a faction — druidic recluses who've been watching the draigons longer than anyone. 4 faction quests. Their specialty is Herbalism mastery and enchanting. Getting in good with them pays off.",
      "Enchanting is live, and it belongs to Ashenveil. The Verdant Circle unlocks it. 8 crafting recipes — Basic through Elite enchantments — using rune dust, ward shards, moonstone, and draigon essence. One enchantment slot per gear piece. Enchanted gear gets a purple glow and a \u2726 badge on bank tiles. Applying a new enchantment over an old one destroys the old one — no refund.",
      "49 new sprites: 6 outpost buildings, 9 enemies (grove wisp, thornback boar, canopy spider, blighted stag, essence wraith, corrupted treant, root guardian, rune sentinel, ward construct), 8 discovery nodes, 3 combat terrain backgrounds, and 23 NPC animations.",
      { section: "Iron Hollows" },
      "Iron Hollows is open: 25 quests (3 main, 18 side, 4 faction), 11 NPCs, 6 discovery nodes, 3 expedition destinations (Deep Seam CP 28, Ancient Forge CP 42, Draigon Shaft CP 55), and 6 outpost buildings (Consortium Hall, Deep Forge, Miners Hall, Ore Depot, Shaft Entrance, Smeltery). The Ironbound Consortium runs the place. They have opinions about mithril.",
      "The boss encounter system is live — three bosses across both regions, each with a three-phase fight, scripted specials, a segmented HP bar showing phase transitions at 66% and 33%, and a warning banner before each special attack. All three respawn weekly (7-day cooldown). Prepare accordingly.",
      "Ashenveil Warden (Ashenveil: Draigon Ruins) — Range weakness. Recommended CP 40+. First-kill unique: Ashenveil Warden Seed.",
      "Iron Forge Colossus (Iron Hollows: Ancient Forge) — Melee weakness. Recommended CP 48+. First-kill unique: Forge Colossus Core.",
      "Draigon Guardian (Iron Hollows: Draigon Shaft) — Magic weakness. Recommended CP 55+. First-kill unique: Draigon Heart — a rare relic tied to the deepest draigon lore. We'll say more about what it's for when the time is right.",
      "Leaderboards shipped: 4 categories (total level, quest points, Collection Log completion, expedition count). Top 100 per category, friends-only filter, opt-in default. The competitive players know who they are.",
      "43 new sprites: 6 buildings, 6 discovery markers, 3 combat terrain backgrounds, 9 enemies, and 19 NPC animations.",
      "Total art: 585 PNG assets across all regions.",
    ],
  },
  {
    version: "0.2.0",
    date: "2026-03-27",
    type: "devlog",
    title: "The World Gets a Face",
    intro:
      "Everything that was a placeholder is now real. The buildings look like buildings. Your companions walk places. The Saltmire Coast has weather, in the metaphorical sense.",
    changes: [
      "Full Saltmire Coast art pass shipped: 9 enemy sprites, 6 discovery node markers, 6 outpost building sprites, and 3 combat terrain backgrounds. The coast looks like a place you'd want to explore — and also a place you'd drown without the right gear.",
      "Outpost building upgrades are now visible. 40 new sprites across 5 buildings, each with 8 level and branch variants. Your storehouse at level 5 looks nothing like it did at level 1. Good.",
      "Companion walk sprites added for Sable and Thurman. They move through the minimap now instead of teleporting. Small thing. It matters.",
      "Friends list and character inspect shipped: DRGN-XXXX friend codes, search by name or code, full gear/skills/Collection Log preview on any friend's profile. The social layer is in.",
      "Audio expansion complete: all 6 regions have 4 ambient tracks each. 28 total music files including the Draigon Ruin audio layer (fades in when you enter ruins, fades out when you leave). The quiet moments are no longer silent.",
    ],
  },
  {
    version: "0.1.0",
    date: "2026-03-20",
    type: "devlog",
    title: "The Foundations Are Laid",
    intro:
      "The Hearthfire Inn is open. The world is built. The quest board has actual quests on it. We shipped Phase 1.",
    changes: [
      "Character creation is live — 4 races (Human, Elven, Draigonkin, Dwarven), 32 portraits, 9 racial bonuses that actually affect gameplay. Your race shows up on the home screen, in skill tooltips, and in the expedition setup. You feel it.",
      "Briarhold and Saltmire Coast are fully implemented: 25 quests with a prerequisite unlock tree, narrative dialogue, item turn-ins, and quest points. Everything gates on story, not just levels.",
      "All 16 skills are scaffolded with resource nodes, XP tables, and milestone unlocks. We front-loaded this work so future regions just need content, not engine changes.",
      "The expedition system is live: 6 destinations across 2 regions, active play (focus tapping, Critical Spark, Gathering Surge, crossroads decisions, battle encounters), provisions, combat style triangle.",
      "The bank is open. 100 slots to start, expandable past 500. Collection Log tracking every item you've ever touched. Bank value counter because we know you're going to flex it.",
      "Firebase is configured: cloud saves with anonymous auth, auto-sync every 5 minutes. Your progress goes with you.",
      "456 unit tests passing. The systems under the hood are stable.",
    ],
  },
];
---

<BaseLayout
  title="Patch Notes"
  description="Draigon Idle patch notes — follow every update, fix, and new feature as the game evolves."
>
  <section class="section" aria-labelledby="patch-title">
    <div class="container">
      <p class="section-label">Development Updates</p>
      <h1 class="section-title" id="patch-title">Patch Notes</h1>
      <p class="section-body">
        Track every update to Draigon Idle — new features, balance changes, and
        bug fixes. The game is actively in development; expect frequent updates.
      </p>

      <ol class="patch-list" reversed aria-label="Version history">
        {
          patches.map(({ version, date, title, type, intro, changes }) => (
            <li class="patch-entry">
              <header class="patch-entry-header">
                <span class="patch-version">
                  {type === "devlog" ? version : `v${version}`}
                </span>
                <time
                  class="patch-date"
                  datetime={date !== "Coming Soon" ? date : undefined}
                >
                  {date}
                </time>
                <span style="color: var(--color-text-muted); font-size: var(--text-sm);">
                  — {title}
                </span>
              </header>
              {intro && (
                <blockquote class="patch-intro">{intro}</blockquote>
              )}
              <ul
                class="patch-changes"
                style="list-style: disc; padding-left: var(--space-6);"
              >
                {changes.map((item) =>
                  typeof item === "string" ? (
                    <li style="margin-bottom: var(--space-1);">{item}</li>
                  ) : (
                    <li class="patch-section-heading">{item.section}</li>
                  )
                )}
              </ul>
            </li>
          ))
        }
      </ol>
    </div>
  </section>
</BaseLayout>

<style>
  .patch-intro {
    border-left: 3px solid var(--color-accent-dim);
    margin: 0 0 var(--space-4);
    padding: var(--space-2) var(--space-4);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-style: italic;
    line-height: var(--leading-normal);
  }

  .patch-section-heading {
    list-style: none;
    margin-left: calc(-1 * var(--space-6));
    margin-top: var(--space-4);
    margin-bottom: var(--space-2);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-accent);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
</style>
