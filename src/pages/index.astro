---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";

// Update discordMemberCount to the current server size (rounded down).
// The member count callout is hidden when below 100.
const discordMemberCount = 0;

const features = [
  {
    icon: "🗺️",
    title: "Explore Six Regions",
    description:
      "From Briarhold's forest paths to the frozen ruins of the Pale Reach — six distinct regions, each with quests, factions, and discovery nodes hidden off the beaten path.",
  },
  {
    icon: "🏕️",
    title: "Build Your Guild",
    description:
      "Recruit companions and dispatch them on expeditions. Return hours later to see how it went — and whether they followed the plan.",
  },
  {
    icon: "⚔️",
    title: "Train Sixteen Skills",
    description:
      "Smithing, Herbalism, Mining, Enchanting, and twelve more. Every skill level opens new gear, new recipes, and new paths through the world.",
  },
  {
    icon: "🏛️",
    title: "Uncover Draigon Ruins",
    description:
      "The ancient draigons shaped the world, then vanished. Their ruins are saturated with residual power — and every one hides a fragment of the truth.",
  },
  {
    icon: "🛡️",
    title: "Watch Your Gear Evolve",
    description:
      "From scavenged leather to draigon-forged plate, every equipment upgrade is visible on your character. Progression you can actually see.",
  },
  {
    icon: "📱",
    title: "Play Anywhere",
    description:
      "Idle progress while you're away, meaningful decisions when you check in. Short session or long — Draigon Idle works around your schedule.",
  },
];
---

<BaseLayout title="Draigon Idle">
  <!-- Hero -->
  <Hero />

  <!-- Features -->
  <section class="section" aria-labelledby="features-title">
    <div class="container">
      <p class="section-label">Why Play</p>
      <h2 class="section-title" id="features-title">Explore. Quest. Return.</h2>
      <p class="section-body">
        Draigon Idle is a narrative idle RPG built around exploration and
        discovery. Every region, every quest, and every ruin has a reason to go
        there.
      </p>

      <ul class="features-grid" role="list">
        {
          features.map(({ icon, title, description }) => (
            <li class="feature-card">
              <div class="feature-icon" aria-hidden="true">
                {icon}
              </div>
              <h3 class="feature-title">{title}</h3>
              <p class="feature-desc">{description}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Wiki -->
  <section class="section wiki-promo" aria-labelledby="wiki-title">
    <div class="container">
      <p class="section-label">The Wiki</p>
      <h2 class="section-title" id="wiki-title">Explore the Wiki</h2>
      <p class="section-body">
        Items, skills, quests, regions, factions — everything in the world of Draigon Idle, documented by the community.
      </p>
      <br />
      <a href="https://wiki.draigonidle.com" class="btn btn-outline" target="_blank" rel="noopener noreferrer">Browse the Wiki</a>
    </div>
  </section>

  <!-- Email Signup -->
  <section class="section email-signup" aria-labelledby="signup-title">
    <div class="container">
      <p class="section-label" id="signup-title">Get Notified</p>
      <p class="signup-tagline">Get notified when Draigon Idle launches. No spam — launch news and devlogs only.</p>
      <div class="signup-embed">
        <script is:inline async data-uid="6b4067efe9" src="https://draigon-idle.kit.com/6b4067efe9/index.js"></script>
      </div>
    </div>
  </section>

  <!-- Community -->
  <section class="section discord-section" aria-labelledby="community-title">
    <div class="container">
      <p class="section-label">The Community</p>
      <div class="discord-logo" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 127.14 96.36" focusable="false">
          <path fill="#5865F2" d="M107.7,8.07A105.15,105.15,0,0,0,81.47,0a72.06,72.06,0,0,0-3.36,6.83A97.68,97.68,0,0,0,49,6.83,72.37,72.37,0,0,0,45.64,0,105.89,105.89,0,0,0,19.39,8.09C2.79,32.65-1.71,56.6.54,80.21h0A105.73,105.73,0,0,0,32.71,96.36,77.7,77.7,0,0,0,39.6,85.25a68.42,68.42,0,0,1-10.85-5.18c.91-.66,1.8-1.34,2.66-2a75.57,75.57,0,0,0,64.32,0c.87.71,1.76,1.39,2.66,2a68.68,68.68,0,0,1-10.87,5.19,77,77,0,0,0,6.89,11.1A105.25,105.25,0,0,0,126.6,80.22h0C129.24,52.84,122.09,29.11,107.7,8.07ZM42.45,65.69C36.18,65.69,31,60,31,53s5-12.74,11.43-12.74S54,46,53.89,53,48.84,65.69,42.45,65.69Zm42.24,0C78.41,65.69,73.25,60,73.25,53s5-12.74,11.44-12.74S96.23,46,96.12,53,91.08,65.69,84.69,65.69Z"/>
        </svg>
      </div>
      <h2 class="section-title" id="community-title">Join us on Discord.</h2>
      {discordMemberCount >= 100 && (
        <p class="discord-member-count">Join {discordMemberCount.toLocaleString()}+ dragon tamers.</p>
      )}
      <p class="section-body">
        The Discord server is the main hub — dev updates, bug reports, feature suggestions, and conversations about what the draigons were actually up to. Wren runs the welcome channel. She's very proud of it.
      </p>
      <br />
      <a href="https://discord.gg/hat7XYJ5" class="btn btn-discord" target="_blank" rel="noopener noreferrer">Join the Server</a>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section" aria-labelledby="cta-title" style="text-align: center;">
    <div class="container">
      <p class="section-label">Stay Updated</p>
      <h2 class="section-title" id="cta-title">Launch is Coming</h2>
      <p class="section-body" style="margin-inline: auto;">
        Draigon Idle is in active development. Follow Stonemill Studios for launch
        news, sneak peeks, and early access updates.
      </p>
      <br />
      <div class="hero-cta-group">
        <a href="/patch-notes" class="btn btn-outline">Patch Notes</a>
        <a href="/press-kit" class="btn btn-outline">Press Kit</a>
        <a href="https://stonemillstudios.com" class="btn btn-primary">
          Stonemill Studios
        </a>
      </div>
      <p class="cta-social">
        Join the conversation on <a href="https://discord.gg/hat7XYJ5" target="_blank" rel="noopener noreferrer">Discord</a>, follow development on <a href="https://x.com/DraigonIdle" target="_blank" rel="noopener noreferrer">Twitter/X</a> and <a href="https://www.reddit.com/user/draigonidle/" target="_blank" rel="noopener noreferrer">Reddit</a>.
      </p>
    </div>
  </section>
</BaseLayout>
