---
const navLinks = [
  { href: "/", label: "Home" },
  { href: "/patch-notes", label: "Patch Notes" },
  { href: "/press-kit", label: "Press Kit" },
  { href: "https://wiki.draigonidle.com", label: "Wiki", external: true },
];

const { pathname } = Astro.url;
---

<header class="site-header" role="banner">
  <div class="container">
    <a href="/" class="site-logo" aria-label="Draigon Idle — Home">
      Draigon Idle
    </a>

    <nav class="site-nav" aria-label="Main navigation">
      {navLinks.map(({ href, label, external }) => (
        <a
          href={href}
          aria-current={pathname === href ? "page" : undefined}
          target={external ? "_blank" : undefined}
          rel={external ? "noopener noreferrer" : undefined}
        >
          {label}
        </a>
      ))}
    </nav>

    <details class="mobile-nav">
      <summary class="hamburger" aria-label="Open navigation menu">
        <span class="hamburger-bar"></span>
        <span class="hamburger-bar"></span>
        <span class="hamburger-bar"></span>
      </summary>
      <div class="mobile-overlay" role="dialog" aria-modal="true" aria-label="Navigation menu">
        <nav aria-label="Mobile navigation">
          {navLinks.map(({ href, label, external }) => (
            <a
              href={href}
              aria-current={pathname === href ? "page" : undefined}
              target={external ? "_blank" : undefined}
              rel={external ? "noopener noreferrer" : undefined}
            >
              {label}
            </a>
          ))}
        </nav>
      </div>
    </details>
  </div>
</header>

<script>
  // Scroll-aware nav: fully opaque background after 80px
  const header = document.querySelector('.site-header') as HTMLElement | null;

  function onScroll() {
    if (window.scrollY >= 80) {
      header?.setAttribute('data-scrolled', '');
    } else {
      header?.removeAttribute('data-scrolled');
    }
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
