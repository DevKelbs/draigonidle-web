        <li><a href="/press-kit">Press Kit</a></li>
        <li><a href="https://wiki.draigonidle.com" target="_blank" rel="noopener noreferrer">Wiki</a></li>
        <li><a href="/privacy">Privacy</a></li>
        <li><a href="/terms">Terms</a></li>
