---
// Hero.astro — placeholder treatment (gradient + SVG dragon silhouette)
// STO-391
//
// Real key art swap: when art is ready, set --hero-art on .hero in a
// page-level <style> or via inline style:
//   <section class="hero" style="--hero-art: url('/art/hero-key.webp')">
//
// The background-image stack is: var(--hero-art, none), then the gradient fallback.
// When --hero-art resolves to a url(), it renders on top of the gradient.
---

<section class="hero" aria-labelledby="hero-title">

  <!-- Layer 1: SVG dragon silhouette (mid-layer, z-index 1) -->
  <div class="hero-silhouette" aria-hidden="true">
    <svg
      viewBox="0 0 800 600"
      xmlns="http://www.w3.org/2000/svg"
      fill="currentColor"
      aria-hidden="true"
      focusable="false"
    >
      <!-- Body -->
      <path d="M310 295 C345 270,415 268,462 290 C508 312,518 346,498 368 C478 390,428 392,382 378 C336 364,292 330,310 295Z"/>
      <!-- Neck -->
      <path d="M332 298 C308 272,278 240,262 215 C246 190,250 172,266 180 C278 186,295 210,315 245 C330 272,340 292,334 300Z"/>
      <!-- Head -->
      <path d="M260 182 C238 174,212 168,198 178 C184 188,188 205,206 212 C224 218,252 212,264 196 C274 182,272 174,260 182Z"/>
      <!-- Snout -->
      <path d="M202 180 C180 172,162 168,154 178 C146 188,158 200,176 200 C194 200,204 190,202 180Z"/>
      <!-- Horn 1 -->
      <path d="M212 168 L205 135 L222 162Z"/>
      <!-- Horn 2 -->
      <path d="M232 162 L228 128 L244 156Z"/>
      <!-- Left wing (bat-wing with three membrane fingers) -->
      <path d="M328 298 L78 72 L128 168 L72 195 L138 215 L172 262 L138 282 L218 280 L295 294Z"/>
      <!-- Right wing (mirror) -->
      <path d="M448 298 L718 72 L668 168 L724 195 L658 215 L624 262 L658 282 L578 280 L501 294Z"/>
      <!-- Tail -->
      <path d="M492 362 C538 372,578 360,618 376 C650 390,658 412,635 420 C612 428,586 408,558 396 C530 384,504 372,492 370Z"/>
      <!-- Tail arrowhead -->
      <path d="M632 414 L672 396 L654 424Z"/>
      <!-- Front leg -->
      <path d="M352 368 L335 420 L347 422 L368 368Z"/>
      <path d="M335 418 L318 440 L346 426Z"/>
      <path d="M346 421 L330 444 L355 428Z"/>
      <!-- Back leg -->
      <path d="M445 380 L430 428 L442 430 L460 380Z"/>
      <path d="M430 426 L414 448 L440 434Z"/>
      <path d="M441 429 L426 450 L450 436Z"/>
    </svg>
  </div>

  <!-- Layer 2: Vignette overlay (z-index 2) -->
  <div class="hero-vignette" aria-hidden="true"></div>

  <!-- Layer 3: Content (z-index 3) -->
  <div class="container hero-inner">
    <p class="section-label">Available on iOS &amp; Android</p>
    <h1 class="hero-title" id="hero-title">
      The world doesn't wait for you.<br />
      <span>It rewards those who return.</span>
    </h1>
    <p class="hero-tagline">
      A narrative idle adventure RPG where you build a guild, train skills, and explore
      the ruins of an ancient civilization — even while you sleep.
    </p>

    <!-- App Store Badges -->
    <div class="badge-group" role="list" aria-label="Download links">
      <a
        href="#"
        class="badge-placeholder"
        role="listitem"
        aria-label="Download on the App Store (coming soon)"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"
          ></path>
        </svg>
        App Store — Coming Soon
      </a>

      <a
        href="#"
        class="badge-placeholder"
        role="listitem"
        aria-label="Get it on Google Play (coming soon)"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M3 20.5v-17c0-.83.94-1.3 1.6-.8l14 8.5c.6.37.6 1.23 0 1.6l-14 8.5c-.66.5-1.6.03-1.6-.8zm2-13.47V17l10.14-4.97L5 7.03z"
          ></path>
        </svg>
        Google Play — Coming Soon
      </a>
    </div>
  </div>
</section>

<style>
  /* ============================================================
     Hero — placeholder treatment
     All hero styles scoped to this component.
     Art swap: set --hero-art on .hero when real key art is ready.
     ============================================================ */

  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
    /*
      Art-swap slot.
      Real key art: --hero-art: url('/art/hero-key.webp')
      Falls back to gradient when unset.
    */
    background-image: var(--hero-art, none),
      radial-gradient(
        ellipse 90% 65% at 58% 35%,
        rgba(124, 58, 237, 0.35) 0%,
        rgba(91, 33, 182, 0.12) 45%,
        transparent 70%
      ),
      radial-gradient(
        ellipse 55% 65% at 18% 78%,
        rgba(124, 58, 237, 0.12) 0%,
        transparent 58%
      );
    background-color: var(--color-bg);
    background-size: cover, auto, auto;
    background-position: center, center, center;
    background-repeat: no-repeat, no-repeat, no-repeat;
  }

  /* Ambient glow — pulsing pseudo-element at z-index 0 */
  .hero::before {
    content: "";
    position: absolute;
    inset: -10%;
    pointer-events: none;
    background: radial-gradient(
      ellipse 68% 58% at 57% 38%,
      rgba(124, 58, 237, 0.24) 0%,
      transparent 62%
    );
    z-index: 0;
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero::before {
      animation: heroGlow 6s ease-in-out infinite;
    }
  }

  @keyframes heroGlow {
    0%, 100% {
      opacity: 0.55;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.1);
    }
  }

  /* Dragon silhouette — z-index 1 */
  .hero-silhouette {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    pointer-events: none;
    overflow: hidden;
  }

  .hero-silhouette svg {
    width: clamp(280px, 52vw, 700px);
    height: auto;
    color: rgba(124, 58, 237, 0.13);
    transform: translateX(14%) translateY(4%);
    flex-shrink: 0;
  }

  /* Vignette overlay — z-index 2 */
  .hero-vignette {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background:
      radial-gradient(
        ellipse 72% 62% at 22% 52%,
        transparent 22%,
        rgba(13, 13, 20, 0.62) 100%
      ),
      linear-gradient(
        to bottom,
        rgba(13, 13, 20, 0.28) 0%,
        transparent 18%,
        transparent 74%,
        rgba(13, 13, 20, 0.62) 100%
      );
  }

  /* Content — z-index 3 */
  .hero-inner {
    position: relative;
    z-index: 3;
    padding-block: var(--space-20) var(--space-16);
  }

  /* Fluid hero title — clamp(2.25rem, 6vw, 5rem) */
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 6vw, 5rem);
    font-weight: var(--weight-bold);
    color: var(--color-text);
    letter-spacing: 0.03em;
    line-height: var(--leading-tight);
    margin-bottom: var(--space-4);
  }

  .hero-title span {
    color: var(--color-accent);
  }

  .hero-tagline {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 52ch;
    margin-inline: auto;
    margin-bottom: var(--space-8);
  }

  /* Badge hover lift — overrides global transition to include transform + shadow */
  .badge-placeholder {
    transition:
      border-color var(--transition-fast),
      color var(--transition-fast),
      transform var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  .badge-placeholder:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(124, 58, 237, 0.22);
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
</style>
